msgstr "核心执行交接在适配器执行前必须保持 commit_execution=false。"

#: includes/Rest/Controller.php:5658
msgid ""
"Core execution handoff must keep core_proxy_execute=false for Adapter "
"execution."
msgstr "核心执行交接必须保持 core_proxy_execute=false 才能由适配器执行。"

#: includes/Rest/Controller.php:5644
msgid ""
"Core execution handoff was not issued for the WordPress Abilities REST "
"surface."
msgstr "核心执行交接不是为 WordPress Abilities REST 执行面签发的。"

#: includes/Rest/Controller.php:5629
msgid "Core execution handoff was not issued for Adapter after Core preflight."
msgstr "核心执行交接不是为核心预检后的适配器执行签发的。"

#: includes/Rest/Controller.php:5616
msgid "Core commit preflight did not return an Adapter execution handoff."
msgstr "核心提交预检未返回适配器执行交接。"

